<!DOCTYPE html>
<html lang="uk">
<head>
  <%- include('partials/head') %>
  <title>Напої — Bunker Pub</title>
</head>
<body>
  <div id="bg1" class="bg-layer"></div>
  <div id="bg2" class="bg-layer"></div>
  <script id="bg-data" type="application/json"><%- JSON.stringify(backgrounds) %></script>

  <div class="page">
    <div class="container">
      <a href="/menu" class="arrow">
        <img src="/img/icon/arrowback.svg" alt=""> Повернутись назад
      </a>

      <div class="tabs">
        <button class="tab active" data-target="vine">Вино</button>
        <button class="tab" data-target="coctel">Коктейлі</button>
        <button class="tab" data-target="firedring">Залпові</button>
        <button class="tab" data-target="alcohol">Алкогольні</button>
        <button class="tab" data-target="freedrink">Безалкогольні</button>
        <button class="tab" data-target="shota">Сети</button>
      </div>

      <div class="tab-content active" id="vine">
        <h2 class="section-title">Вино</h2>
        <div class="menu-table">
          <div class="menu-row menu-header">
            <span>Назва</span><span>Опис</span><span>Об'єм</span><span>Ціна</span>
          </div>
          <% menu.falseDataVine.forEach(function(item, i) { %>
          <div class="menu-row" style="animation-delay:<%- i * 0.04 %>s">
            <span><%= item.name %></span><span><%= item.about %></span>
            <span><%= item.volume %></span><span><%= item.price %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <div class="tab-content" id="coctel">
        <h2 class="section-title">Коктейлі</h2>
        <div class="menu-table">
          <div class="menu-row menu-header">
            <span>Назва</span><span>Опис</span><span>Об'єм</span><span>Ціна</span>
          </div>
          <% menu.falseDataCoctel.forEach(function(item, i) { %>
          <div class="menu-row" style="animation-delay:<%- i * 0.04 %>s">
            <span><%= item.name %></span><span><%= item.about %></span>
            <span><%= item.volume %></span><span><%= item.price %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <div class="tab-content" id="firedring">
        <h2 class="section-title">Залпові коктейлі</h2>
        <div class="menu-table">
          <div class="menu-row menu-header">
            <span>Назва</span><span>Опис</span><span>Об'єм</span><span>Ціна</span>
          </div>
          <% menu.falseDataFireDrink.forEach(function(item, i) { %>
          <div class="menu-row" style="animation-delay:<%- i * 0.04 %>s">
            <span><%= item.name %></span><span><%= item.about %></span>
            <span><%= item.volume %></span><span><%= item.price %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <div class="tab-content" id="alcohol">
        <h2 class="section-title">Алкогольні напої</h2>
        <div class="menu-table">
          <div class="menu-row menu-header">
            <span>Назва</span><span>Опис</span><span>Об'єм</span><span>Ціна</span>
          </div>
          <% menu.falseDataAlcohol.forEach(function(item, i) { %>
          <div class="menu-row" style="animation-delay:<%- i * 0.04 %>s">
            <span><%= item.name %></span><span><%= item.about %></span>
            <span><%= item.volume %></span><span><%= item.price %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <div class="tab-content" id="freedrink">
        <h2 class="section-title">Безалкогольні напої</h2>
        <div class="menu-table">
          <div class="menu-row menu-header">
            <span>Назва</span><span></span><span>Об'єм</span><span>Ціна</span>
          </div>
          <% menu.falseDataFreeDrink.forEach(function(item, i) { %>
          <div class="menu-row" style="animation-delay:<%- i * 0.04 %>s">
            <span><%= item.name %></span><span></span>
            <span><%= item.volume %></span><span><%= item.price %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <div class="tab-content" id="shota">
        <h2 class="section-title">Сети</h2>
        <div class="menu-table">
          <div class="menu-row menu-header">
            <span>Назва</span><span>Опис</span><span>Об'єм</span><span>Ціна</span>
          </div>
          <% menu.falseDataShota.forEach(function(item, i) { %>
          <div class="menu-row" style="animation-delay:<%- i * 0.04 %>s">
            <span><%= item.name %></span><span><%= item.about %></span>
            <span><%= item.volume %></span><span><%= item.price %></span>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/bg.js"></script>
  <script src="/js/tabs.js"></script>
</body>
</html>
